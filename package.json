{
  "name": "ytdlp-downloader",
  "version": "1.0.0",
  "description": "Downloader video e audio con yt-dlp",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ytdlpdownloader.ytdl",
    "productName": "AL YT-DLP Downloader",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "style.css",
      "package.json",
      "!Bin/**",
      "!*.bat",
      "!*.7z",
      "!README.md"
    ],
    "extraResources": [
      {
        "from": "Bin/",
        "to": "bin",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": ["**/*.node"],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^26.2.0",
    "electron-builder": "^24.6.0"
  }
}
